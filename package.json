{
  "name": "alpha-badges-coming-soon",
  "version": "1.0.0",
  "description": "Coming Soon landing page for Alpha Badges and Medals Pty Ltd, built with Tailwind CSS.",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/css/input.css -o ./dist/css/output.css --minify",
    "build:js": "copyfiles -u 2 \"src/js/**/*.js\" dist/js",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "tailwindcss -i ./src/css/input.css -o ./dist/css/output.css --watch",
    "dev": "npm run build:js && npm run watch:css"
  },
  "keywords": [
    "tailwindcss",
    "landing-page",
    "coming-soon"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "copyfiles": "2.4.1",
    "postcss-load-config": "3.1.4",
    "sucrase": "3.21.0",
    "tailwindcss": "3.2.7"
  }
}
